APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://hackatonshik.ru
FORCE_HTTPS=true

# Comma-separated proxy IPs/CIDRs (e.g. load balancer subnets), or * to trust all (not recommended in production).
# Behind TLS-terminating ingress you MUST list real proxy IPs so X-Forwarded-For / client IP and rate limits are correct.
# Leave empty only for single-server deployments with no reverse proxy.
TRUSTED_PROXIES=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
# Для русских данных в `php artisan db:seed` (фабрики Faker)
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily,stderr,telegram
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Telescope (dev-only package; provider loads only when installed)
TELESCOPE_ENABLED=false

# Advanced Monitoring
HORIZON_PREFIX=hackatonshik_horizon:
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
# Keep enabled in production to protect session payloads at rest.
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_CONNECTION=cache
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="${APP_URL}"
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

OCTANE_SERVER=roadrunner
OCTANE_HOST=0.0.0.0
OCTANE_PORT=8000
OCTANE_WORKERS=auto
OCTANE_TASK_WORKERS=auto
OCTANE_MAX_REQUESTS=500
OCTANE_HTTPS=false
OCTANE_MAX_EXECUTION_TIME=30
OCTANE_GARBAGE=50

PULSE_ENABLED=false
# Production: set PULSE_ENABLED=true and run deploy/supervisor/pulse.conf + schedule pulse:check
PULSE_PATH=pulse
PULSE_STORAGE_DRIVER=database
PULSE_INGEST_DRIVER=storage
PULSE_CACHE_DRIVER=redis

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Yandex OAuth: enable login:default_phone permission in oauth.yandex.ru app settings.
# Register both callback URLs from `php artisan oauth:redirect-uris` in the Yandex app console.
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# VK ID OAuth: extended phone scope requires a verified business profile in VK ID console.
# Register the VK callback URL from `php artisan oauth:redirect-uris` in the VK ID console.
VK_CLIENT_ID=
VK_CLIENT_SECRET=

PLUSOFON_API_URL=
PLUSOFON_API_TOKEN=
PLUSOFON_SENDER=

PLUSOFON_FLASH_CALL_ENABLED=false
PLUSOFON_FLASH_CALL_BASE_URL=https://restapi.plusofon.ru/api/v1
PLUSOFON_FLASH_CALL_TOKEN=
PLUSOFON_FLASH_CALL_CLIENT=10553

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Laravel Sail (локальная разработка в Docker)
# Скопируйте шаблон: cp .env.sail .env  (или: composer sail:setup)
# Стек: PostgreSQL + Redis + Mailpit + Reverb (см. compose.yaml)
# APP_URL=http://localhost, FORCE_HTTPS=false
# DB_HOST=pgsql, REDIS_HOST=redis, MAIL_HOST=mailpit
# REVERB_HOST=localhost, REVERB_PORT=8080, REVERB_SCHEME=http
# Почта в UI: http://localhost:8025
# Для Herd без Docker используйте отдельный .env (SQLite / https://*.test)
# ---------------------------------------------------------------------------