{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "hackatonshik/platform",
    "type": "project",
    "description": "\u041f\u043b\u0430\u0442\u0444\u043e\u0440\u043c\u0430 \u0434\u043b\u044f \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0438 \u0445\u0430\u043a\u0430\u0442\u043e\u043d\u043e\u0432, \u043a\u043e\u043c\u0430\u043d\u0434, \u0437\u0430\u044f\u0432\u043e\u043a, \u043a\u0435\u0439\u0441\u043e\u0432, \u0441\u043a\u043e\u0440\u0438\u043d\u0433\u0430 \u0438 \u0441\u0435\u0440\u0442\u0438\u0444\u0438\u043a\u0430\u0442\u043e\u0432.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "barryvdh/laravel-dompdf": "^3.1",
        "filament/filament": "^5.6",
        "laravel/fortify": "^1.35",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.46",
        "laravel/octane": "^2.17",
        "laravel/pulse": "^1.7",
        "laravel/reverb": "^1.0",
        "laravel/socialite": "^5.26",
        "laravel/tinker": "^2.10.1",
        "league/commonmark": "^2.8",
        "livewire/blaze": "^1.0",
        "livewire/livewire": "^4.2",
        "robsontenorio/mary": "^2.8",
        "socialiteproviders/vkontakte": "^5.1",
        "socialiteproviders/yandex": "^4.1",
        "spatie/laravel-activitylog": "^5.0",
        "spatie/laravel-markdown": "^2.8",
        "spiral/roadrunner-cli": "^2.7",
        "spiral/roadrunner-http": "^4.1"
    },
    "require-dev": {
        "enlightn/security-checker": "^2.0",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/boost": "^2.2",
        "laravel/dusk": "*",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.57",
        "laravel/telescope": "^5.20",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "sail": "docker compose exec laravel.test",
        "sail:up": [
            "docker compose up -d"
        ],
        "sail:down": [
            "docker compose down"
        ],
        "sail:setup": [
            "@php -r \"copy('.env.sail', '.env');\"",
            "docker compose up -d",
            "docker compose exec -T laravel.test composer install",
            "docker compose exec -T laravel.test php artisan key:generate --force",
            "docker compose exec -T laravel.test php artisan migrate --seed --force",
            "docker compose exec -T laravel.test npm install",
            "docker compose exec -T laravel.test npm run build"
        ],
        "sail:dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"docker compose exec -T laravel.test php artisan horizon\" \"docker compose exec -T laravel.test php artisan reverb:start\" \"docker compose exec -T laravel.test npm run dev -- --host\" --names=horizon,reverb,vite --kill-others"
        ],
        "lint": [
            "pint --parallel"
        ],
        "lint:check": [
            "pint --parallel --test"
        ],
        "analyse": [
            "vendor/bin/phpstan analyse --memory-limit=512M"
        ],
        "precommit:quick": [
            "@lint:check",
            "phpstan analyse app routes --memory-limit=1G",
            "@php artisan test --compact tests/Feature/Policies tests/Feature/FortifyAuthenticationTest.php"
        ],
        "ci:check": [
            "Composer\\Config::disableProcessTimeout",
            "@lint:check",
            "@analyse",
            "@php artisan test"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@lint:check",
            "@php artisan test"
        ],
        "test:rebuild": [
            "@php artisan config:clear --ansi",
            "@php artisan cache:clear --ansi",
            "@php artisan test --compact"
        ],
        "dusk:prepare": [
            "@php -r \"file_exists('database/dusk.sqlite') || touch('database/dusk.sqlite');\"",
            "@php artisan migrate --force --env=dusk",
            "@php artisan storage:link --env=dusk",
            "@php artisan dusk:chrome-driver --detect"
        ],
        "dusk": [
            "Composer\\Config::disableProcessTimeout",
            "@dusk:prepare",
            "@php artisan dusk"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "block-insecure": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
